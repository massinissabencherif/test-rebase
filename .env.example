# Fichier .env pour docker-compose.yml (prod)
# Copier en .env et remplir les valeurs

NODE_ENV=production
POSTGRES_PASSWORD=comicster_secret
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
SESSION_SECRET=change_me_in_production
TOTP_ENCRYPTION_KEY=replace_with_64_hex_chars
PGADMIN_PASSWORD=change_me_in_production
UMAMI_SECRET=change_me_in_production

# URLs
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# URL de l'API vue depuis le navigateur (pas depuis le conteneur)
NUXT_PUBLIC_API_BASE=http://localhost:3001

# OAuth2 Google (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth2 GitHub (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Marvel API (optionnel)
MARVEL_PUBLIC_KEY=
MARVEL_PRIVATE_KEY=
