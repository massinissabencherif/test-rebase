# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Base de données ──────────────────────────────────────────────────────────
# Dev local (PostgreSQL installé sur la machine)
DATABASE_URL="postgresql://massinissabencherif@localhost:5432/comicster?schema=public"

# Dev avec Docker Compose (docker-compose.dev.yml)
# DATABASE_URL="postgresql://comicster:comicster_secret@localhost:5432/comicster"

# Production Docker (docker-compose.yml) — défini automatiquement via compose
# DATABASE_URL="postgresql://comicster:${POSTGRES_PASSWORD}@postgres:5432/comicster"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT_SECRET : secret de signature des access tokens (15 min)
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_me_in_production"
JWT_EXPIRES_IN="15m"

# ─── Session (flux OAuth uniquement) ─────────────────────────────────────────
# SESSION_SECRET doit être DISTINCT de JWT_SECRET
# Générer : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="change_me_in_production"

# ─── Chiffrement TOTP ─────────────────────────────────────────────────────────
# Clé AES-256 pour chiffrer les secrets TOTP en base de données
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DOIT être une chaîne hex de exactement 64 caractères (32 octets)
TOTP_ENCRYPTION_KEY="change_me_64_hex_chars_aabbccddeeff00112233445566778899aabbccddeeff0011"

# ─── Docker (prod uniquement) ─────────────────────────────────────────────────
POSTGRES_PASSWORD="comicster_secret"

# ─── URLs ─────────────────────────────────────────────────────────────────────
API_BASE_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# ─── OAuth2 Google ────────────────────────────────────────────────────────────
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OAuth2 GitHub ────────────────────────────────────────────────────────────
# https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Marvel API (optionnel) ───────────────────────────────────────────────────
# https://developer.marvel.com/
MARVEL_PUBLIC_KEY=""
MARVEL_PRIVATE_KEY=""
