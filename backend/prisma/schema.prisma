// Comicster — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String?
  oauthProvider String?
  oauthId       String?
  role          Role      @default(USER)
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  readingEntries ReadingEntry[]
  reviews        Review[]
  lists          List[]
  following      Follow[]       @relation("follower")
  followers      Follow[]       @relation("following")
  comments       Comment[]
  refreshTokens  RefreshToken[]
  badges         UserBadge[]
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower",  fields: [followerId],  references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
  @@index([followingId])
}

// ─── Comics ──────────────────────────────────────────────────────────────────

model Comic {
  id          String    @id @default(cuid())
  externalId  String    @unique
  title       String
  description String?
  coverUrl    String?
  pdfUrl      String?
  genres      String[]
  authors     String[]
  publisher   String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  readingEntries ReadingEntry[]
  reviews        Review[]
  listItems      ListItem[]
  authorLinks    AuthorOnComic[]
}

// ─── Journal de lecture ───────────────────────────────────────────────────────

model ReadingEntry {
  id         String        @id @default(cuid())
  userId     String
  comicId    String
  status     ReadingStatus @default(TO_READ)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user  User  @relation(fields: [userId],  references: [id])
  comic Comic @relation(fields: [comicId], references: [id])

  @@unique([userId, comicId])
  @@index([userId])
  @@index([userId, status])
}

enum ReadingStatus {
  TO_READ
  IN_PROGRESS
  FINISHED
}

// ─── Avis ────────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  comicId   String
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId],  references: [id])
  comic    Comic     @relation(fields: [comicId], references: [id])
  comments Comment[]

  @@unique([userId, comicId])
  @@index([comicId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  content   String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id])
  review Review @relation(fields: [reviewId], references: [id])

  @@index([reviewId])
}

// ─── Auteurs ─────────────────────────────────────────────────────────────────

model Author {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  bio       String?
  photoUrl  String?
  birthDate DateTime?
  comics    AuthorOnComic[]

  @@index([slug])
}

model AuthorOnComic {
  authorId String
  comicId  String

  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comic  Comic  @relation(fields: [comicId],  references: [id], onDelete: Cascade)

  @@id([authorId, comicId])
}

// ─── Badges ──────────────────────────────────────────────────────────────────

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeKey String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
}

// ─── Listes personnalisées ───────────────────────────────────────────────────

model List {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String   @unique
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  items ListItem[]

  @@index([userId])
}

model ListItem {
  listId  String
  comicId String
  addedAt DateTime @default(now())

  list  List  @relation(fields: [listId],  references: [id])
  comic Comic @relation(fields: [comicId], references: [id])

  @@id([listId, comicId])
}
