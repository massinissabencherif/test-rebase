// Comicster — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String?
  oauthProvider String?
  oauthId       String?
  role          Role      @default(USER)
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  readingEntries ReadingEntry[]
  reviews        Review[]
  lists          List[]
  following      Follow[]       @relation("follower")
  followers      Follow[]       @relation("following")
  comments       Comment[]
  commentLikes   CommentLike[]
  reviewLikes    ReviewLike[]
  refreshTokens  RefreshToken[]
  badges         UserBadge[]
  guideTopics    GuideTopic[]   @relation("GuideTopic_author")
  guideReplies   GuideReply[]   @relation("GuideReply_author")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Code temporaire à usage unique pour le flux OAuth (expire en 2 min)
model OAuthCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower",  fields: [followerId],  references: [id])
  following User @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
  @@index([followingId])
}

// ─── Comics ──────────────────────────────────────────────────────────────────

model Comic {
  id          String    @id @default(cuid())
  externalId  String    @unique
  title       String
  description String?
  coverUrl    String?
  pdfUrl      String?
  genres      String[]
  authors     String[]
  publisher   String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  readingEntries ReadingEntry[]
  reviews        Review[]
  listItems      ListItem[]
  authorLinks    AuthorOnComic[]
}

// ─── Journal de lecture ───────────────────────────────────────────────────────

model ReadingEntry {
  id          String        @id @default(cuid())
  userId      String
  comicId     String
  status      ReadingStatus @default(TO_READ)
  currentPage Int?
  totalPages  Int?
  progress    Int           @default(0)
  startedAt   DateTime?
  finishedAt  DateTime?
  lastReadAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user  User  @relation(fields: [userId],  references: [id])
  comic Comic @relation(fields: [comicId], references: [id])

  @@unique([userId, comicId])
  @@index([userId])
  @@index([userId, status])
}

enum ReadingStatus {
  TO_READ
  IN_PROGRESS
  FINISHED
}

// ─── Avis ────────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  userId    String
  comicId   String
  rating    Int
  content   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User         @relation(fields: [userId],  references: [id])
  comic    Comic        @relation(fields: [comicId], references: [id])
  comments Comment[]
  likes    ReviewLike[]

  @@unique([userId, comicId])
  @@index([comicId])
}

model ReviewLike {
  userId    String
  reviewId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
  @@index([reviewId])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  reviewId  String
  content   String
  createdAt DateTime @default(now())

  user   User          @relation(fields: [userId],   references: [id])
  review Review        @relation(fields: [reviewId], references: [id])
  likes  CommentLike[]

  @@index([reviewId])
}

model CommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

// ─── Auteurs ─────────────────────────────────────────────────────────────────

model Author {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  bio       String?
  photoUrl  String?
  birthDate DateTime?
  comics    AuthorOnComic[]

  @@index([slug])
}

model AuthorOnComic {
  authorId String
  comicId  String

  author Author @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comic  Comic  @relation(fields: [comicId],  references: [id], onDelete: Cascade)

  @@id([authorId, comicId])
}

// ─── Badges ──────────────────────────────────────────────────────────────────

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeKey String
  earnedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@index([userId])
}

// ─── Listes personnalisées ───────────────────────────────────────────────────

model List {
  id          String   @id @default(cuid())
  userId      String
  name        String
  slug        String   @unique
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id])
  items ListItem[]

  @@index([userId])
}

model ListItem {
  listId  String
  comicId String
  addedAt DateTime @default(now())

  list  List  @relation(fields: [listId],  references: [id], onDelete: Cascade)
  comic Comic @relation(fields: [comicId], references: [id], onDelete: Cascade)

  @@id([listId, comicId])
}

// ─── Guides de lecture (Parcours) ───────────────────────────────────────────

model ReadingGuide {
  id           String       @id @default(cuid())
  slug         String       @unique
  character    String
  imageUrl     String?
  teaser       String
  story        String
  relatedSlugs String[]     @default([])
  comics       GuideComic[]
  topics       GuideTopic[]
  createdAt    DateTime     @default(now())
}

model GuideComic {
  id       String       @id @default(cuid())
  guide    ReadingGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  guideId  String
  title    String
  coverUrl String?
  comicUrl String?
  note     String
  order    Int          @default(0)

  @@index([guideId])
}

model GuideTopic {
  id        String       @id @default(cuid())
  guide     ReadingGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)
  guideId   String
  author    User         @relation("GuideTopic_author", fields: [authorId], references: [id])
  authorId  String
  title     String
  content   String
  imageUrl  String?
  replies   GuideReply[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([guideId])
}

model GuideReply {
  id        String       @id @default(cuid())
  topic     GuideTopic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId   String
  parent    GuideReply?  @relation("ReplyThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentId  String?
  children  GuideReply[] @relation("ReplyThread")
  author    User         @relation("GuideReply_author", fields: [authorId], references: [id])
  authorId  String
  content   String
  imageUrl  String?
  createdAt DateTime     @default(now())

  @@index([topicId])
  @@index([parentId])
}
